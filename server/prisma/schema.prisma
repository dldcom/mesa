// MESA Database Schema
// 운영 데이터(유저 계정, 세션 기록)만 관리.
// 게임 콘텐츠 에셋(Character/Item/Map/NPC)은 mesa/assets/ 폴더에 파일로 저장됨 (DB 아님).
// 결정 이력은 docs/CONTEXT_FOR_CLAUDE.md 의 "에셋 저장 방식" 섹션 참조.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  role      Role      @default(TEACHER)
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  teacherId Int
  teacher   User      @relation(fields: [teacherId], references: [id])
  startedAt DateTime?
  endedAt   DateTime?
  teams     TeamLog[]
  createdAt DateTime  @default(now())
}

model TeamLog {
  id               Int      @id @default(autoincrement())
  sessionId        Int
  session          Session  @relation(fields: [sessionId], references: [id])
  teamName         String
  students         String[] // 학생 이름 배열
  completedActs    Int      @default(0)
  totalTimeSeconds Int?
  createdAt        DateTime @default(now())
}
